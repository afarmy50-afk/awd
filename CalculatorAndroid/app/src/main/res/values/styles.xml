<resources>
    <style name="Theme.Calculator" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="CalcButtonBase">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="CalcButtonNumber" parent="CalcButtonBase">
        <item name="android:backgroundTint">#333333</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="CalcButtonFunction" parent="CalcButtonBase">
        <item name="android:backgroundTint">#A5A5A5</item>
        <item name="android:textColor">#000000</item>
    </style>

    <style name="CalcButtonOperator" parent="CalcButtonBase">
        <item name="android:backgroundTint">#FF9500</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="CalcButtonEquals" parent="CalcButtonBase">
        <item name="android:backgroundTint">#FF9500</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>
</resources>
