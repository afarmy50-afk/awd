<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="#1E1E1E">

    <!-- صفحه نمایش -->
    <TextView
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="bottom|end"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="48sp"
        android:padding="16dp" />

    <!-- ردیف ۱: C, ←, %, / -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btnClear" style="@style/CalcButtonFunction" android:text="C" />
        <Button android:id="@+id/btnBackspace" style="@style/CalcButtonFunction" android:text="←" />
        <Button android:id="@+id/btnPercent" style="@style/CalcButtonFunction" android:text="%" />
        <Button android:id="@+id/btnDivide" style="@style/CalcButtonOperator" android:text="÷" />
    </LinearLayout>

    <!-- ردیف ۲: 7, 8, 9, * -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btn7" style="@style/CalcButtonNumber" android:text="7" />
        <Button android:id="@+id/btn8" style="@style/CalcButtonNumber" android:text="8" />
        <Button android:id="@+id/btn9" style="@style/CalcButtonNumber" android:text="9" />
        <Button android:id="@+id/btnMultiply" style="@style/CalcButtonOperator" android:text="×" />
    </LinearLayout>

    <!-- ردیف ۳: 4, 5, 6, - -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btn4" style="@style/CalcButtonNumber" android:text="4" />
        <Button android:id="@+id/btn5" style="@style/CalcButtonNumber" android:text="5" />
        <Button android:id="@+id/btn6" style="@style/CalcButtonNumber" android:text="6" />
        <Button android:id="@+id/btnSubtract" style="@style/CalcButtonOperator" android:text="−" />
    </LinearLayout>

    <!-- ردیف ۴: 1, 2, 3, + -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btn1" style="@style/CalcButtonNumber" android:text="1" />
        <Button android:id="@+id/btn2" style="@style/CalcButtonNumber" android:text="2" />
        <Button android:id="@+id/btn3" style="@style/CalcButtonNumber" android:text="3" />
        <Button android:id="@+id/btnAdd" style="@style/CalcButtonOperator" android:text="+" />
    </LinearLayout>

    <!-- ردیف ۵: 0, ., = -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btn0" style="@style/CalcButtonNumber"
            android:text="0" android:layout_weight="2" />
        <Button android:id="@+id/btnDot" style="@style/CalcButtonNumber" android:text="." />
        <Button android:id="@+id/btnEquals" style="@style/CalcButtonEquals" android:text="=" />
    </LinearLayout>

</LinearLayout>
